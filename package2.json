{
  "name": "timewise-ai",
  "private": true,
  "version": "0.1.0",
  "description": "TimeWise AI Intelligent Workforce Orchestration Platform",
  "scripts": {
    "dev": "concurrently \"npm:start-backend\" \"npm:start-frontend\"",
    "start-backend": "nodemon --watch backend/src --exec node backend/src/index.js",
    "start-frontend": "cd frontend && npm run dev -- --host 0.0.0.0",
    "install-all": "cd backend && npm install && cd ../frontend && npm install",
    "build": "cd frontend && npm run build",
    "start": "node backend/src/index.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1"
  }
}
